# =============================================
# CONDOAPP BACKEND — Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# =============================================

# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados PostgreSQL (preencha com os dados do EasyPanel)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=condoapp
DB_USER=condoapp_user
DB_PASSWORD=SUA_SENHA_AQUI

# JWT — troque por uma string longa e aleatória!
JWT_SECRET=mude_esta_chave_secreta_para_algo_muito_seguro_123
JWT_EXPIRES_IN=7d

# CORS — URL do seu frontend
FRONTEND_URL=http://localhost:8100

# Upload de arquivos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
